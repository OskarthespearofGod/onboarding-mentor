<idea-plugin>
    <id>com.onboardingmentor</id>
    <name>Onboarding Mentor</name>
    <vendor>oskaras-noreikis</vendor>

    <description><![CDATA[
    A mentor that explains classes using Anthropic API.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable parentId="tools" instance="com.onboardingmentor.settings.MentorSettingsConfigurable"
                                 id="com.onboardingmentor.settings.MentorSettingsConfigurable"
                                 displayName="Onboarding Mentor"/>
        
        <toolWindow id="Onboarding Mentor" anchor="right" icon="AllIcons.Toolwindows.ToolWindow"
                    factoryClass="com.onboardingmentor.ui.MentorToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="com.onboardingmentor.actions.AnalyzeClassAction"
                class="com.onboardingmentor.actions.AnalyzeClassAction"
                text="Explain with Onboarding Mentor"
                description="Use Onboarding Mentor to explain this class">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>